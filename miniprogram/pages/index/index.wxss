.writer {
  --content-x: 60rpx;
  --intro-x: 72rpx;
  --writing-light: 0.06;
  --line-light: 0.06;
  --lamp-presence: 0;
  --room-quiet: 0;
  --stage-breath: 0;
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(ellipse 70% 72% at 34% 48%, rgba(31, 21, 21, calc(0.44 - var(--room-quiet) * 0.08)), transparent 68%),
    radial-gradient(ellipse 54% 64% at 86% 43%, rgba(18, 20, 33, calc(0.58 - var(--room-quiet) * 0.12)), transparent 70%),
    linear-gradient(
      180deg,
      rgb(var(--bg-r), var(--bg-g), var(--bg-b)) 0%,
      rgb(var(--end-r), var(--end-g), var(--end-b)) 130%
    );
  animation: night-entry 900ms ease both;
  isolation: isolate;
}

button {
  -webkit-appearance: none;
  appearance: none;
  display: block;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: normal;
}

button::after {
  border: 0;
}

.glow,
.vignette,
.stars {
  position: absolute;
  pointer-events: none;
}

.glow {
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1;
  overflow: hidden;
  background: transparent;
}

.has-text .glow {
  animation: lamp-switch-on 760ms cubic-bezier(0.2, 0.86, 0.2, 1) both;
}

.glow::before {
  position: absolute;
  top: -12%;
  right: -6%;
  bottom: -12%;
  left: -6%;
  content: "";
  background:
    radial-gradient(ellipse 34% 24% at 31% 31%, rgba(255, 224, 154, calc(var(--lamp-presence) * 0.18)), transparent 68%),
    radial-gradient(ellipse 28% 34% at 29% 41%, rgba(189, 119, 81, calc(var(--lamp-presence) * 0.1)), transparent 72%),
    radial-gradient(ellipse 42% 18% at 34% 30%, rgba(226, 204, 145, calc(var(--writing-light) + var(--stage-breath) * 0.05)), transparent 70%),
    radial-gradient(ellipse 56% 30% at 38% 46%, rgba(189, 119, 81, calc(var(--glow-alpha) + 0.06)), transparent 74%),
    linear-gradient(104deg, transparent 8%, rgba(226, 204, 145, calc(var(--writing-light) * 0.52)) 36%, rgba(189, 119, 81, calc(var(--writing-light) * 0.66)) 57%, transparent 78%);
  filter: blur(28rpx);
  opacity: calc(0.88 - var(--room-quiet) * 0.06);
  pointer-events: none;
  transform: rotate(-6deg);
}

.has-text .glow::before {
  animation: writing-light-breathe 6200ms ease-in-out infinite;
}

.glow::after {
  position: absolute;
  top: 36%;
  left: var(--content-x);
  width: calc(100vw - var(--content-x) * 2);
  height: 520rpx;
  content: "";
  background:
    linear-gradient(90deg, transparent, rgba(226, 204, 145, var(--line-light)), transparent) 0 0 / 100% 1rpx no-repeat,
    linear-gradient(90deg, transparent, rgba(226, 204, 145, calc(var(--line-light) * 0.76)), transparent) 0 172rpx / 100% 1rpx no-repeat,
    linear-gradient(90deg, transparent, rgba(226, 204, 145, calc(var(--line-light) * 0.54)), transparent) 0 344rpx / 100% 1rpx no-repeat;
  opacity: calc(0.44 - var(--room-quiet) * 0.04);
  pointer-events: none;
  transform: rotate(-5deg);
}

.vignette {
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 4;
  opacity: var(--vignette-alpha);
  background: radial-gradient(ellipse 80% 78% at 45% 46%, transparent 36%, rgba(3, 4, 9, calc(0.58 + var(--room-quiet) * 0.08)) 100%);
}

.stars {
  top: -18%;
  right: -18%;
  bottom: -18%;
  left: -18%;
  z-index: 0;
  background-image:
    radial-gradient(circle at 18% 20%, rgba(92, 108, 152, 0.12) 0 1px, transparent 1.5px),
    radial-gradient(circle at 78% 16%, rgba(215, 182, 110, 0.1) 0 1px, transparent 1.5px),
    radial-gradient(circle at 84% 74%, rgba(92, 108, 152, 0.12) 0 1px, transparent 1.5px),
    radial-gradient(circle at 28% 82%, rgba(215, 182, 110, 0.08) 0 1px, transparent 1.5px);
}

.intro {
  position: absolute;
  top: 100rpx;
  right: 284rpx;
  left: var(--intro-x);
  z-index: 22;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  color: rgba(132, 145, 181, 0.66);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 26rpx;
  letter-spacing: 1rpx;
  line-height: 1.7;
  pointer-events: none;
}

.has-text .intro {
  opacity: 0;
  transform: translateY(-8rpx);
}

.keyword-layer {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  pointer-events: none;
  transition: opacity 400ms ease;
}

.keyword {
  position: absolute;
  padding: 16rpx 20rpx;
  border: 0;
  background: transparent;
  color: rgba(114, 128, 164, 0.18);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 26rpx;
  letter-spacing: 4rpx;
  line-height: 1.4;
  opacity: 0;
  pointer-events: auto;
  text-shadow: none;
  transform: translate3d(0, 8rpx, 0);
  transition:
    color 1800ms ease,
    opacity 1600ms ease,
    text-shadow 1800ms ease,
    transform 1600ms ease;
}

.keyword.visible {
  opacity: 1;
  transform: translate3d(0, 0, 0);
}

.keyword.active {
  opacity: 1;
  color: rgba(215, 182, 110, 0.88);
  text-shadow:
    0 0 28rpx rgba(255, 195, 90, 0.44),
    0 0 56rpx rgba(255, 145, 45, 0.2);
}

.keyword-0 {
  top: 25% !important;
  left: var(--content-x) !important;
}

.keyword-1 {
  top: 23% !important;
  right: 18% !important;
  left: auto !important;
}

.keyword-2 {
  top: 42% !important;
  right: 10% !important;
}

.keyword-3 {
  top: 64% !important;
  left: var(--content-x) !important;
}

.keyword-4 {
  right: 10% !important;
  bottom: 17% !important;
}

.has-text .keyword.visible {
  opacity: 0.46;
  color: rgba(125, 137, 174, 0.34);
}

.has-text .keyword.active {
  opacity: 1;
}

.keyword.releasing {
  animation: keyword-release 760ms ease both;
}

.textarea {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 240rpx var(--content-x) 176rpx;
  color: #e2cc91;
  caret-color: rgba(214, 169, 101, 0.86);
  background: transparent;
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 38rpx;
  line-height: 2.08;
  letter-spacing: 1.6rpx;
  text-shadow:
    0 0 36rpx rgba(226, 204, 145, calc(var(--text-glow) * 0.12)),
    0 0 72rpx rgba(189, 119, 81, calc(var(--text-glow) * 0.16));
}

.history-open .textarea,
.history-open .keyword-layer,
.history-open .intro,
.history-open .clear-tonight,
.history-open .save-status,
.clear-open .textarea,
.clear-open .keyword-layer,
.clear-open .intro,
.clear-open .clear-tonight,
.clear-open .save-status {
  opacity: 0.18;
  filter: blur(0.6px);
}

.placeholder {
  color: rgba(114, 128, 164, 0.36);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
}

.history-dot {
  position: absolute;
  top: 52rpx;
  right: 36rpx;
  z-index: 65;
  box-sizing: border-box;
  min-width: 208rpx;
  min-height: 88rpx;
  width: auto;
  height: 88rpx;
  border-radius: 999rpx;
  opacity: 1;
  overflow: visible;
}

.history-dot-mark {
  position: absolute;
  top: 36rpx;
  right: 16rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(112, 127, 168, 0.52);
  box-shadow: 0 0 16rpx rgba(112, 127, 168, 0.2);
}

.history-hint {
  position: absolute;
  top: 50%;
  right: 52rpx;
  width: max-content;
  color: rgba(132, 145, 181, 0.66);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  line-height: 1;
  opacity: 0.58;
  pointer-events: none;
  transform: translate3d(0, -50%, 0);
  white-space: nowrap;
}

.history-hint.visible {
  opacity: 0.78;
  transform: translate3d(0, -50%, 0);
}

.history-scrim {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 50;
  background: rgba(2, 3, 8, 0.42);
  opacity: 0;
  pointer-events: none;
  transition: opacity 360ms ease;
}

.history-scrim.open {
  opacity: 1;
  pointer-events: auto;
}

.history-panel {
  position: absolute;
  top: auto;
  right: 24rpx;
  bottom: 24rpx;
  left: 24rpx;
  z-index: 90;
  box-sizing: border-box;
  width: auto;
  max-height: min(62vh, calc(100vh - 224rpx));
  display: flex;
  flex-direction: column;
  overflow: hidden;
  padding: 36rpx 36rpx 32rpx;
  border: 1rpx solid rgba(125, 137, 174, 0.26);
  border-radius: 16rpx 16rpx 12rpx 12rpx;
  background: linear-gradient(180deg, rgba(14, 16, 27, 0.98), rgba(8, 9, 16, 0.99));
  box-shadow:
    0 40rpx 120rpx rgba(2, 3, 8, 0.52),
    inset 0 1rpx 0 rgba(216, 199, 158, 0.08);
  opacity: 0;
  pointer-events: none;
  transform: translate3d(0, 28rpx, 0);
  transition:
    opacity 320ms ease,
    transform 420ms ease,
    visibility 320ms ease;
  visibility: hidden;
}

.history-panel::before {
  position: absolute;
  top: 16rpx;
  left: 50%;
  width: 84rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(114, 128, 164, 0.32);
  content: "";
  transform: translateX(-50%);
}

.history-panel.open {
  opacity: 1;
  pointer-events: auto;
  transform: translate3d(0, 0, 0);
  visibility: visible;
}

.history-top {
  flex: 0 0 auto;
  display: grid;
  grid-template-columns: 88rpx 1fr 88rpx;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.history-title {
  color: rgba(216, 199, 158, 0.84);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 28rpx;
  font-weight: 400;
  letter-spacing: 6rpx;
  text-align: center;
}

.history-back,
.history-close,
.history-back-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  color: rgba(132, 145, 181, 0.76);
  font-size: 48rpx;
  line-height: 60rpx;
  text-align: center;
}

.history-list,
.history-detail {
  min-height: 0;
  flex: 1 1 auto;
  max-height: calc(100vh - 332rpx);
  overflow: auto;
}

.history-empty {
  margin: 28rpx 0 8rpx;
  color: rgba(125, 137, 174, 0.7);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 28rpx;
  line-height: 1.8;
}

.history-row {
  display: block;
  width: 100%;
  padding: 0 0 24rpx;
  margin-bottom: 22rpx;
  border-bottom: 1rpx solid rgba(116, 127, 160, 0.11);
}

.history-date {
  display: block;
  color: rgba(112, 127, 168, 0.86);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

.history-text {
  display: -webkit-box;
  margin-top: 14rpx;
  overflow: hidden;
  color: rgba(192, 175, 135, 0.88);
  font-size: 28rpx;
  line-height: 1.78;
  white-space: pre-wrap;
  word-break: break-word;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.history-detail-text {
  display: block;
  margin-top: 14rpx;
  color: rgba(204, 187, 145, 0.92);
  font-size: 30rpx;
  line-height: 1.9;
  white-space: pre-wrap;
  word-break: break-word;
}

.history-footer {
  flex: 0 0 auto;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(116, 127, 160, 0.11);
}

.export-all {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  min-height: 88rpx;
  padding: 0;
  color: rgba(132, 145, 181, 0.78);
  background: transparent;
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  line-height: 1.6;
}

.export-label {
  display: block;
  width: 100%;
  text-align: left;
}

.privacy-note {
  margin-top: 12rpx;
  color: rgba(112, 127, 168, 0.62);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 22rpx;
  line-height: 1.75;
}

.goodnight {
  position: absolute;
  right: 0;
  bottom: 56rpx;
  left: 0;
  z-index: 30;
  color: rgba(198, 136, 82, 0.36);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 24rpx;
  letter-spacing: 10rpx;
  text-align: center;
  animation: goodnight-pulse 3000ms ease-in-out infinite;
}

.clear-tonight {
  position: absolute;
  bottom: 48rpx;
  left: 44rpx;
  z-index: 35;
  min-width: 176rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  color: rgba(125, 137, 174, 0.56);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  opacity: 0;
  pointer-events: none;
}

.has-text .clear-tonight {
  opacity: 1;
  pointer-events: auto;
}

.clear-panel {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  left: 24rpx;
  z-index: 90;
  box-sizing: border-box;
  padding: 40rpx 36rpx 36rpx;
  border: 1rpx solid rgba(114, 128, 164, 0.26);
  border-radius: 16rpx 16rpx 12rpx 12rpx;
  background: linear-gradient(180deg, rgba(14, 16, 27, 0.98), rgba(8, 9, 16, 0.99));
  box-shadow: 0 -40rpx 112rpx rgba(0, 0, 0, 0.54);
  opacity: 0;
  pointer-events: none;
  transform: translate3d(0, 28rpx, 0);
  transition:
    opacity 260ms ease,
    transform 360ms ease,
    visibility 260ms ease;
  visibility: hidden;
}

.clear-panel::before {
  position: absolute;
  top: 16rpx;
  left: 50%;
  width: 84rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(114, 128, 164, 0.32);
  content: "";
  transform: translateX(-50%);
}

.clear-panel.open {
  opacity: 1;
  pointer-events: auto;
  transform: translate3d(0, 0, 0);
  visibility: visible;
}

.clear-question {
  display: block;
  margin: 24rpx 0 32rpx;
  color: rgba(226, 204, 145, 0.9);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 30rpx;
  letter-spacing: 1rpx;
  line-height: 1.6;
}

.clear-actions {
  display: flex;
  gap: 20rpx;
}

.clear-action {
  flex: 1 1 0;
  width: auto;
  min-width: 0;
  min-height: 88rpx;
  box-sizing: border-box;
  border: 0;
  border-radius: 16rpx;
  color: rgba(226, 204, 145, 0.78);
  background: rgba(114, 128, 164, 0.1);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

.clear-confirm {
  background: rgba(189, 119, 81, 0.14);
  color: rgba(226, 204, 145, 0.92);
}

.save-status {
  position: absolute;
  right: 0;
  bottom: 116rpx;
  left: 0;
  z-index: 35;
  color: rgba(132, 145, 181, 0.72);
  font-family: "Night UI WenKai", "LXGW WenKai Screen", "Kaiti SC", "STKaiti", "KaiTi", serif;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  text-align: center;
  opacity: 0;
  pointer-events: none;
  transform: translateY(8rpx);
}

.save-status.visible {
  opacity: 1;
  transform: translateY(0);
}

@keyframes goodnight-pulse {
  0% {
    color: rgba(168, 140, 88, 0.36);
    filter: drop-shadow(0 0 0 rgba(210, 175, 105, 0));
    opacity: 0.42;
  }

  50% {
    color: rgba(220, 188, 120, 0.82);
    filter: drop-shadow(0 0 20rpx rgba(210, 175, 105, 0.22));
    opacity: 1;
  }

  100% {
    color: rgba(168, 140, 88, 0.36);
    filter: drop-shadow(0 0 0 rgba(210, 175, 105, 0));
    opacity: 0.42;
  }
}

@keyframes night-entry {
  0% {
    filter: brightness(0.86) saturate(0.96);
  }

  100% {
    filter: brightness(1) saturate(1);
  }
}

@keyframes keyword-release {
  0% {
    color: rgba(215, 182, 110, 0.88);
    opacity: 1;
    text-shadow:
      0 0 28rpx rgba(255, 195, 90, 0.44),
      0 0 56rpx rgba(255, 145, 45, 0.2);
    transform: translate3d(0, 0, 0);
  }

  100% {
    color: rgba(125, 137, 174, 0.34);
    opacity: 0.46;
    text-shadow: none;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes writing-light-breathe {
  0%,
  100% {
    --stage-breath: 0;
    opacity: 0.86;
  }

  50% {
    --stage-breath: 1;
    opacity: 1;
  }
}

@keyframes lamp-switch-on {
  0% {
    filter: brightness(0.82) saturate(0.96);
    opacity: 0.72;
  }

  18% {
    filter: brightness(1.55) saturate(1.1);
    opacity: 1;
  }

  48% {
    filter: brightness(1.16) saturate(1.04);
    opacity: 1;
  }

  100% {
    filter: brightness(1) saturate(1);
    opacity: 1;
  }
}
