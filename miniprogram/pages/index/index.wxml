<view class="writer {{hasText ? 'has-text' : ''}} {{historyOpen ? 'history-open' : ''}} {{clearConfirmOpen ? 'clear-open' : ''}}" style="{{writerStyle}}" bindtap="focusWriting">
  <view class="glow" aria-hidden="true"></view>
  <view class="vignette" aria-hidden="true"></view>
  <view class="stars" aria-hidden="true"></view>
  <view class="intro" wx:if="{{!hasText}}">
    <text>本机保存</text>
    <text>不登录，不上传</text>
  </view>

  <view class="keyword-layer">
    <view
      wx:for="{{keywordItems}}"
      wx:key="word"
      class="keyword keyword-{{index}} {{item.visible ? 'visible' : ''}} {{item.active ? 'active' : ''}} {{item.releasing ? 'releasing' : ''}}"
      role="button"
      aria-label="插入关键词：{{item.word}}"
      data-keyword="{{item.word}}"
      style="{{item.styleText}}"
      hover-class="none"
      catchtap="insertKeyword"
    >
      {{item.word}}
    </view>
  </view>

  <textarea
    class="textarea"
    value="{{text}}"
    placeholder="写下今晚脑子里放不下的东西…"
    placeholder-class="placeholder"
    maxlength="-1"
    auto-height="{{false}}"
    cursor-spacing="120"
    focus="{{inputFocused}}"
    cursor="{{cursor}}"
    selection-start="{{cursor}}"
    selection-end="{{cursor}}"
    hold-keyboard="{{true}}"
    adjust-position="{{true}}"
    bindinput="onInput"
    bindselectionchange="onSelectionChange"
  ></textarea>

  <view class="history-dot" aria-label="查看过去 7 天" catchtap="toggleHistory">
    <view class="history-dot-mark" wx:if="{{!historyOpen}}"></view>
    <text class="history-hint {{historyHintVisible || historyOpen ? 'visible' : ''}}">过去 7 天</text>
  </view>

  <view class="history-scrim {{historyOpen ? 'open' : ''}}" catchtap="closeHistory"></view>
  <view class="history-panel {{historyOpen ? 'open' : ''}}" catchtap="noop">
    <view class="history-top">
      <view class="history-back" wx:if="{{detailOpen}}" role="button" aria-label="返回历史列表" hover-class="none" catchtap="backToHistory"></view>
      <view class="history-back-placeholder" wx:else></view>
      <text class="history-title">{{detailOpen ? '完整记录' : '过去 7 天'}}</text>
      <view class="history-close" role="button" aria-label="关闭历史" hover-class="none" catchtap="closeHistory"></view>
    </view>

    <scroll-view class="history-list" wx:if="{{!detailOpen}}" scroll-y>
      <view wx:if="{{historyEmpty}}" class="history-empty">还没有留下前几天的文字</view>
      <view
        wx:for="{{history}}"
        wx:key="date"
        class="history-row"
        data-date="{{item.date}}"
        catchtap="openDetail"
      >
        <text class="history-date">{{item.label}}</text>
        <text class="history-text">{{item.preview}}</text>
      </view>
    </scroll-view>

    <scroll-view class="history-detail" wx:else scroll-y>
      <text class="history-date">{{detailEntry.label}}</text>
      <text class="history-detail-text">{{detailEntry.text}}</text>
    </scroll-view>

    <view class="history-footer">
      <view class="export-all" role="button" aria-label="导出全部" hover-class="none" catchtap="exportAll">
        <text class="export-label">导出全部</text>
      </view>
      <view class="privacy-note">不登录，不上传，只保存在这台设备。清理浏览器数据会丢失。</view>
    </view>
  </view>

  <view class="goodnight" wx:if="{{goodnightVisible}}">晚安</view>
  <button class="clear-tonight" wx:if="{{hasText}}" hover-class="none" catchtap="requestClearTonight">清空今晚</button>
  <view class="clear-panel {{clearConfirmOpen ? 'open' : ''}}" catchtap="noop">
    <text class="clear-question">清空今晚写下的内容？</text>
    <view class="clear-actions">
      <view class="clear-action clear-keep" role="button" hover-class="none" catchtap="cancelClearTonight">
        <text class="clear-action-label">保留</text>
      </view>
      <view class="clear-action clear-confirm" role="button" hover-class="none" catchtap="confirmClearTonight">
        <text class="clear-action-label">清空</text>
      </view>
    </view>
  </view>
  <view class="save-status {{saveStatusVisible ? 'visible' : ''}}">{{saveStatus}}</view>
</view>
